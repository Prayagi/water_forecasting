      border-radius: 1px;
      animation: rain-fall linear infinite;
      transform: rotate(-20deg); transform-origin: top center;
    }
    @keyframes rain-fall {
      0% { transform: rotate(-20deg) translateY(-150px); opacity: 0; }
      10% { opacity: 1; } 90% { opacity: 0.7; }
      100% { transform: rotate(-20deg) translateY(110vh); opacity: 0; }
    }

    /* Menu Hero */
    .menu-hero {
      text-align: center; padding: 70px 20px 46px;
