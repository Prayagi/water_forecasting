      font-size: 0.9rem; line-height: 1.55;
    }
    .info-item .check { color: var(--accent-blue); font-size: 1rem; flex-shrink: 0; margin-top: 1px; }

    /* Footer */
    .footer-nav {
      background: #050e1c; color: rgba(255,255,255,0.6);
      display: flex; align-items: center; justify-content: space-between;
