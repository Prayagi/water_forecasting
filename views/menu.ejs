<div class="ocean-bg">
   

  <div class="rain-canvas" id="rain"></div>
 

  <section class="menu-hero">
   <div id="back_button">
        <a href="/" > <button id="b1">
            Go Back
        </button>
        </a> 
    </div> 
    <h1 class="menu-title">WELCOME TO AQUA FORECAST</h1>
    <p class="menu-sub">Empowering sustainable water management with the power of AI.</p>
  </section>
  
  <div class="cards-section">
    <div class="predict-card" onclick="window.open('predict_capacity.html','_blank')">Predict<br>Capacity</div>
    <div class="predict-card" onclick="window.open('predict_water_demand.html','_blank')">Predict Water<br>Demand</div>
    <div class="predict-card" onclick="window.open('predict_sector_risk.html','_blank')">Predict Sector<br>Wise Risk<br>Assessment</div>
    <div class="predict-card" onclick="window.open('predict_risk_assessment.html','_blank')">Predict Risk<br>Assessment</div>
  </div>

  <div class="info-section">
    <div class="info-card">
      <h3>Features</h3>
      <div class="info-item"><span class="check">✔</span><span>AI-driven water availability predictions</span></div>
      <div class="info-item"><span class="check">✔</span><span>Price forecasting for fresh and wastewater</span></div>
      <div class="info-item"><span class="check">✔</span><span>Impact analysis on budgets and accounts</span></div>
    </div>
    <div class="info-card">
      <h3>Benefits</h3>
      <div class="info-item"><span class="check">✔</span><span>High reliability of forecasts</span></div>
      <div class="info-item"><span class="check">✔</span><span>Flexibility in data selection</span></div>
      <div class="info-item"><span class="check">✔</span><span>Zero deviation for long-term predictions</span></div>
    </div>
  </div>

  

