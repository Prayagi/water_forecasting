<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Predict Risk Assessment – Aqua Forecast</title>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&family=Cinzel:wght@600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Raleway', sans-serif;
      background: #eaf4fb;
      min-height: 100vh;
      display: flex; align-items: flex-start; justify-content: center;
      padding: 40px 20px;
    }

    .wrapper { max-width: 820px; width: 100%; display: flex; flex-direction: column; gap: 28px; }

    .card {
      background: #fff; border-radius: 18px;
      box-shadow: 0 4px 32px rgba(42,109,181,0.13);
      padding: 40px 48px 36px; width: 100%;
    }
    .card-title {
      text-align: center; font-size: 1.25rem; font-weight: 700;
      color: #2a6db5; margin-bottom: 32px;
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .card-title svg { width: 22px; height: 22px; fill: #2a6db5; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 32px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    label { font-size: 0.82rem; font-weight: 700; color: #1a3a6e; letter-spacing: 0.04em; }

    input, select {
      border: 1.5px solid #c8dff5; border-radius: 7px;
      padding: 10px 14px; font-size: 0.95rem;
      font-family: 'Raleway', sans-serif; color: #333;
      background: #f5faff; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    }
    input:focus, select:focus { border-color: #2a6db5; background: #fff; box-shadow: 0 0 0 3px rgba(42,109,181,0.1); }

    .btn-wrap { text-align: center; margin-top: 28px; }
    .predict-btn {
      background: linear-gradient(135deg, #2a6db5, #1a5299);
      color: #fff; border: none;
      padding: 13px 44px; border-radius: 9px;
      font-size: 1rem; font-weight: 700;
      font-family: 'Raleway', sans-serif; cursor: pointer; letter-spacing: 0.06em;
      display: inline-flex; align-items: center; gap: 9px;
      transition: all 0.25s; box-shadow: 0 4px 16px rgba(42,109,181,0.3);
    }
    .predict-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(42,109,181,0.4); }
    .predict-btn:active { transform: translateY(0); }
    .predict-btn:disabled { opacity: 0.65; cursor: not-allowed; transform: none; }
    .predict-btn svg { width: 18px; height: 18px; fill: #fff; }

    .loader-wrap {
      display: none; flex-direction: column; align-items: center; gap: 14px;
      padding: 28px 0 8px;
    }
    .loader-wrap.show { display: flex; }
    .spinner {
      width: 42px; height: 42px;
      border: 4px solid #c8dff5;
      border-top-color: #2a6db5;
      border-radius: 50%;
      animation: spin 0.85s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loader-text { color: #2a6db5; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.04em; }

    .result-card {
      background: #fff; border-radius: 18px;
      box-shadow: 0 4px 32px rgba(42,109,181,0.13);
      padding: 36px 48px; width: 100%;
      display: none; animation: slideUp 0.5s ease;
    }
    .result-card.show { display: block; }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .result-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    .result-title {
      font-size: 1.1rem; font-weight: 800; color: #1a3a6e;
      display: flex; align-items: center; gap: 8px;
    }
    .result-title svg { width: 20px; height: 20px; fill: #2a6db5; }

    .risk-badge {
      padding: 7px 22px; border-radius: 30px;
      font-size: 0.85rem; font-weight: 800; letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .risk-LOW      { background: #e6f9ee; color: #1a7a3f; border: 1.5px solid #a3e6be; }
    .risk-MEDIUM   { background: #fff8e1; color: #b07800; border: 1.5px solid #ffe082; }
    .risk-HIGH     { background: #fff0e0; color: #c85c00; border: 1.5px solid #ffcc99; }
    .risk-CRITICAL { background: #ffeaea; color: #c0000a; border: 1.5px solid #ffaaaa; }

    .score-section { margin-bottom: 26px; }
    .score-label { font-size: 0.78rem; font-weight: 700; color: #1a3a6e; letter-spacing: 0.05em; margin-bottom: 8px; }
    .score-bar-wrap { background: #e8f2fb; border-radius: 8px; height: 16px; overflow: hidden; }
    .score-bar { height: 100%; border-radius: 8px; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); width: 0%; }
    .score-num { font-size: 1.7rem; font-weight: 800; color: #1a3a6e; margin-top: 10px; }

    .divider { border: none; border-top: 1.5px solid #e8f2fb; margin: 22px 0; }

    .section-title {
      font-size: 0.8rem; font-weight: 800; color: #2a6db5;
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px;
    }
    .ai-text { font-size: 0.95rem; color: #334; line-height: 1.8; }

    .factors-grid { display: flex; flex-wrap: wrap; gap: 10px; }
    .factor-pill {
      background: #f0f7ff; border: 1.5px solid #c8dff5;
      border-radius: 20px; padding: 6px 16px;
      font-size: 0.82rem; font-weight: 600; color: #1a3a6e;
      display: flex; align-items: center; gap: 7px;
    }
    .factor-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

    .reco-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .reco-list li {
      background: #f5faff; border-left: 3px solid #2a6db5;
      border-radius: 0 8px 8px 0; padding: 11px 16px;
      font-size: 0.91rem; color: #334; line-height: 1.6;
    }

    .error-msg {
      background: #fff0f0; border: 1.5px solid #ffaaaa;
      border-radius: 10px; padding: 14px 18px;
      color: #c0000a; font-size: 0.9rem; font-weight: 600;
      display: none; margin-top: 18px; text-align: center;
    }
    .error-msg.show { display: block; }

    @media(max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .card, .result-card { padding: 28px 20px; }
    }
  </style>
</head>
<body>
<div class="wrapper">

  <div class="card">
    <div class="card-title">
      <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 4l6 2.67V11c0 3.9-2.63 7.55-6 8.93C8.63 18.55 6 14.9 6 11V7.67L12 5zm-1 3v5h2V8h-2zm0 6v2h2v-2h-2z"/></svg>
      Predict Risk Assessment
    </div>

    <div class="form-grid">
      <div class="form-group">
        <label>Location</label>
        <input id="location" type="text" placeholder="e.g. Zone A / Bhopal" />
      </div>
      <div class="form-group">
        <label>Risk Type</label>
        <select id="riskType">
          <option>Flood</option>
          <option>Drought</option>
          <option>Contamination</option>
          <option>Infrastructure Failure</option>
        </select>
      </div>
      <div class="form-group">
        <label>Water Table Level (m)</label>
        <input id="waterTable" type="number" placeholder="e.g. 12.5" step="0.1" />
      </div>
      <div class="form-group">
        <label>Soil Moisture (%)</label>
        <input id="soilMoisture" type="number" placeholder="e.g. 65" />
      </div>
      <div class="form-group">
        <label>Temperature (°C)</label>
        <input id="temperature" type="number" placeholder="e.g. 34" step="0.1" />
      </div>
      <div class="form-group">
        <label>Annual Rainfall (mm)</label>
        <input id="rainfall" type="number" placeholder="e.g. 850" />
      </div>
      <div class="form-group">
        <label>Population Affected</label>
        <input id="population" type="number" placeholder="e.g. 25000" />
      </div>
      <div class="form-group">
        <label>Infrastructure Age (years)</label>
        <input id="infraAge" type="number" placeholder="e.g. 20" />
      </div>
    </div>

    <div class="loader-wrap" id="loader">
      <div class="spinner"></div>
      <div class="loader-text">AI is analysing risk parameters…</div>
    </div>

    <div class="error-msg" id="errorMsg">⚠️ Something went wrong. Please check your inputs and try again.</div>

    <div class="btn-wrap">
      <button class="predict-btn" id="predictBtn" onclick="runPrediction()">
        <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        Predict with AI
      </button>
    </div>
  </div>

  <div class="result-card" id="resultCard">
    <div class="result-header">
      <div class="result-title">
        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        AI Risk Assessment Result
      </div>
      <span class="risk-badge" id="riskBadge">–</span>
    </div>

    <div class="score-section">
      <div class="score-label">OVERALL RISK SCORE</div>
      <div class="score-bar-wrap">
        <div class="score-bar" id="scoreBar"></div>
      </div>
      <div class="score-num" id="scoreNum">–</div>
    </div>

    <hr class="divider"/>

    <div class="section-title">📋 AI Analysis</div>
    <div class="ai-text" id="aiAnalysis">–</div>

    <hr class="divider"/>

    <div class="section-title">⚠️ Key Risk Factors</div>
    <div class="factors-grid" id="factorsGrid"></div>

    <hr class="divider"/>

    <div class="section-title">✅ Recommendations</div>
    <ul class="reco-list" id="recoList"></ul>
  </div>

</div>

<script>
async function runPrediction() {
  const btn    = document.getElementById('predictBtn');
  const loader = document.getElementById('loader');
  const errMsg = document.getElementById('errorMsg');
  const result = document.getElementById('resultCard');

  const data = {
    location    : document.getElementById('location').value     || 'Not specified',
    riskType    : document.getElementById('riskType').value,
    waterTable  : document.getElementById('waterTable').value   || 'N/A',
    soilMoisture: document.getElementById('soilMoisture').value || 'N/A',
    temperature : document.getElementById('temperature').value  || 'N/A',
    rainfall    : document.getElementById('rainfall').value     || 'N/A',
    population  : document.getElementById('population').value   || 'N/A',
    infraAge    : document.getElementById('infraAge').value     || 'N/A',
  };

  btn.disabled = true;
  loader.classList.add('show');
  errMsg.classList.remove('show');
  result.classList.remove('show');

  const prompt = `You are an expert water resource risk assessment AI for the Aqua Forecast system in Madhya Pradesh, India.

Analyze the following parameters and produce a detailed water risk assessment:

- Location: ${data.location}
- Risk Type: ${data.riskType}
- Water Table Level: ${data.waterTable} m
- Soil Moisture: ${data.soilMoisture}%
- Temperature: ${data.temperature}°C
- Annual Rainfall: ${data.rainfall} mm
- Population Affected: ${data.population}
- Infrastructure Age: ${data.infraAge} years

Respond ONLY with a valid JSON object — no markdown fences, no preamble, just raw JSON:
{
  "riskLevel": "LOW" or "MEDIUM" or "HIGH" or "CRITICAL",
  "riskScore": <integer 0-100>,
  "scoreColor": "<a meaningful hex color: green for low, yellow for medium, orange for high, red for critical>",
  "analysis": "<3-4 sentences of expert analysis explaining the risk situation in context of Madhya Pradesh water management>",
  "keyFactors": [
    { "label": "<factor name>", "color": "<hex color matching severity>" }
  ],
  "recommendations": [
    "<specific actionable recommendation 1>",
    "<specific actionable recommendation 2>",
    "<specific actionable recommendation 3>",
    "<specific actionable recommendation 4>"
  ]
}`;

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    const apiData = await response.json();
    const raw = apiData.content.map(b => b.text || '').join('');
    const clean = raw.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);
    renderResult(parsed);

  } catch (err) {
    console.error(err);
    errMsg.classList.add('show');
  } finally {
    btn.disabled = false;
    loader.classList.remove('show');
  }
}

function renderResult(d) {
  const badge = document.getElementById('riskBadge');
  badge.textContent = d.riskLevel;
  badge.className = 'risk-badge risk-' + d.riskLevel;

  const bar = document.getElementById('scoreBar');
  bar.style.background = d.scoreColor || '#2a6db5';
  bar.style.width = '0%';
  setTimeout(() => { bar.style.width = d.riskScore + '%'; }, 120);
  document.getElementById('scoreNum').textContent = d.riskScore + ' / 100';
  document.getElementById('scoreNum').style.color = d.scoreColor || '#1a3a6e';

  document.getElementById('aiAnalysis').textContent = d.analysis;

  const grid = document.getElementById('factorsGrid');
  grid.innerHTML = '';
  (d.keyFactors || []).forEach(f => {
    const pill = document.createElement('div');
    pill.className = 'factor-pill';
    pill.innerHTML = `<span class="factor-dot" style="background:${f.color}"></span>${f.label}`;
    grid.appendChild(pill);
  });

  const list = document.getElementById('recoList');
  list.innerHTML = '';
  (d.recommendations || []).forEach(r => {
    const li = document.createElement('li');
    li.textContent = r;
    list.appendChild(li);
  });

  document.getElementById('resultCard').classList.add('show');
  setTimeout(() => {
    document.getElementById('resultCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 100);
}
</script>
</body>
</html>
